# Maintainer: Blaine Miller <blaine@wemiller.com>
# AUR package: haven-desktop — the Tauri GUI client (also runs headless as a relay with
# `--headless`). The web UI is static and embedded into the binary at compile time, so the
# build needs no Node/npm — just Rust + the system WebKitGTK.
#
#   git clone https://aur.archlinux.org/haven-desktop.git && cd haven-desktop && makepkg -si
#
pkgname=haven-desktop
pkgver=0.1.0
pkgrel=1
pkgdesc="Haven — private, post-quantum, peer-to-peer social network (desktop client + relay)"
arch=('x86_64' 'aarch64')
url="https://github.com/blaineam/haven"
license=('LicenseRef-PolyForm-Noncommercial-1.0.0')
depends=('webkit2gtk-4.1' 'gtk3' 'libayatana-appindicator' 'pipewire')
optdepends=('xdg-desktop-portal: camera + screen-share portals'
            'xdg-desktop-portal-gtk: portal backend')
makedepends=('rust' 'cargo' 'git')
provides=('haven-desktop')
conflicts=('haven-desktop-bin')
options=('!lto')
source=("git+https://github.com/blaineam/haven.git")
sha256sums=('SKIP')

build() {
  cd "$srcdir/haven/desktop/src-tauri"
  export RUSTUP_TOOLCHAIN=stable
  export CARGO_TARGET_DIR="$srcdir/target"
  # Static frontend (ui/) is baked in by tauri-build; no bundler step.
  cargo build --release --frozen 2>/dev/null || cargo build --release
}

package() {
  install -Dm755 "$srcdir/target/release/haven-desktop" "$pkgdir/usr/bin/haven-desktop"

  install -Dm644 "$srcdir/haven/desktop/flatpak/com.blaineam.haven.desktop" \
    "$pkgdir/usr/share/applications/com.blaineam.haven.desktop"
  install -Dm644 "$srcdir/haven/desktop/flatpak/com.blaineam.haven.metainfo.xml" \
    "$pkgdir/usr/share/metainfo/com.blaineam.haven.metainfo.xml"

  for px in 32 128; do
    install -Dm644 "$srcdir/haven/desktop/src-tauri/icons/${px}x${px}.png" \
      "$pkgdir/usr/share/icons/hicolor/${px}x${px}/apps/com.blaineam.haven.png"
  done
}
