# Maintainer: Blaine Miller <blaine@wemiller.com>
# AUR package: haven-relay — the headless, always-on Haven circle relay/mailbox daemon.
# Builds the tiny single binary from source (no GUI / no webkit), installs a hardened
# systemd *system* service plus a sysusers entry for the `haven-relay` service account.
#
#   git clone https://aur.archlinux.org/haven-relay.git && cd haven-relay && makepkg -si
#
pkgname=haven-relay
pkgver=0.0.1
pkgrel=1
pkgdesc="Always-on Haven circle relay + sealed-media mailbox (ciphertext only, no server)"
arch=('x86_64' 'aarch64' 'armv7h')
url="https://github.com/blaineam/haven"
license=('LicenseRef-PolyForm-Noncommercial-1.0.0')
depends=('gcc-libs')
makedepends=('rust' 'cargo' 'git')
backup=()
install="${pkgname}.install"
options=('!lto')
# Alpha: build from the repo. Pin to a tag/commit once releases are cut.
source=("git+https://github.com/blaineam/haven.git")
sha256sums=('SKIP')

build() {
  cd "$srcdir/haven/core"
  export RUSTUP_TOOLCHAIN=stable
  export CARGO_TARGET_DIR="$srcdir/target"
  cargo build --release --frozen --package haven-relay 2>/dev/null \
    || cargo build --release --package haven-relay
}

package() {
  install -Dm755 "$srcdir/target/release/haven-relay" "$pkgdir/usr/bin/haven-relay"
  install -Dm644 "$srcdir/haven/relay/debian/haven-relay.service" \
    "$pkgdir/usr/lib/systemd/system/haven-relay.service"
  install -Dm644 "$srcdir/haven/relay/README.md" \
    "$pkgdir/usr/share/doc/haven-relay/README.md"

  # Declarative service account + state dir (systemd-sysusers / -tmpfiles).
  install -dm755 "$pkgdir/usr/lib/sysusers.d" "$pkgdir/usr/lib/tmpfiles.d"
  printf 'u haven-relay - "Haven relay" /var/lib/haven-relay /usr/bin/nologin\n' \
    > "$pkgdir/usr/lib/sysusers.d/haven-relay.conf"
  printf 'd /var/lib/haven-relay 0750 haven-relay haven-relay -\n' \
    > "$pkgdir/usr/lib/tmpfiles.d/haven-relay.conf"
}
